<script>
  // 1) TYPING EFFECT for title (catchy & serious)
  const titles = ["Data Analyst", "Cyber Security Analyst", "Phil Wilson · Threat & Analytics"];
  let idx = 0;
  let charIdx = 0;
  let isDeleting = false;
  const typedSpan = document.getElementById("typed-text");

  function typeEffect() {
    const current = titles[idx];
    if (isDeleting) {
      typedSpan.innerText = current.substring(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) {
        isDeleting = false;
        idx = (idx + 1) % titles.length;
      }
    } else {
      typedSpan.innerText = current.substring(0, charIdx + 1);
      charIdx++;
      if (charIdx === current.length) {
        isDeleting = true;
        setTimeout(() => {}, 1500);
      }
    }
    setTimeout(typeEffect, isDeleting ? 80 : 120);
  }
  typeEffect();

  // 2) SKILL BARS ANIMATION ON SCROLL (Intersection Observer)
  const skillBars = document.querySelectorAll('.skill-bar-fill');
  
  function animateBars() {
    skillBars.forEach(bar => {
      const width = bar.getAttribute('data-width');
      if (width && !bar.style.width) {
        bar.style.width = width + '%';
      }
    });
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateBars();
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  const skillsSection = document.querySelector('.skills-grid');
  if (skillsSection) observer.observe(skillsSection);

  // fallback: if observer never triggers (small screen fast), but also attach on window load
  window.addEventListener('load', () => {
    // if already visible trigger manually
    const rect = skillsSection?.getBoundingClientRect();
    if (rect && rect.top < window.innerHeight - 100) {
      animateBars();
    } else {
      // still observe
      if(skillsSection) observer.observe(skillsSection);
    }
  });

  // ensure each bar initial width = 0 so they fill smoothly
  skillBars.forEach(bar => {
    bar.style.width = '0%';
    const targetWidth = bar.getAttribute('data-width');
    bar.setAttribute('data-original-width', targetWidth);
  });

  // re-run animateBars if already observed later but we need better: set width only after seen.
  // already we check on observer, but for better robustness
  function fillVisibleBars() {
    if(!skillsSection) return;
    const rect = skillsSection.getBoundingClientRect();
    if (rect.top < window.innerHeight - 80 && rect.bottom > 0) {
      animateBars();
    }
  }
  window.addEventListener('scroll', () => {
    if(!skillsSection) return;
    const rect = skillsSection.getBoundingClientRect();
    if (rect.top < window.innerHeight - 80 && rect.bottom > 0 && !window._barsAnimated) {
      animateBars();
      window._barsAnimated = true;
    }
  });
  
  // ensure bars only animate once after being visible (global flag to avoid repeated)
  let animatedFlag = false;
  const originalAnimate = animateBars;
  window.animateBarsOnce = function() {
    if(!animatedFlag) {
      originalAnimate();
      animatedFlag = true;
    }
  };
  // overwrite observer callback to trigger once
  const newObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !animatedFlag) {
        animateBars();
        animatedFlag = true;
      }
    });
  }, { threshold: 0.2 });
  if (skillsSection) newObserver.observe(skillsSection);
  
  // also initial check after a tiny delay (DOM ready)
  setTimeout(() => {
    if (skillsSection && skillsSection.getBoundingClientRect().top < window.innerHeight - 80 && !animatedFlag) {
      animateBars();
      animatedFlag = true;
    }
  }, 300);

  // 3) SMOOTH SCROLL for any internal anchor (if needed for future) plus interactive cards hover already works.
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      const href = this.getAttribute('href');
      if (href !== "#" && href !== "") {
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
        }
      }
    });
  });

  // 4) DOWNLOAD PDF BUTTON: stylish placeholder (alerts that it's a web version)
  const downloadBtn = document.getElementById('downloadBtn');
  if (downloadBtn) {
    downloadBtn.addEventListener('click', () => {
      alert("📄 PDF version ready for download.\n(static demo — in production, generate dynamic PDF using jsPDF or server)\nMeanwhile, you can print this page as PDF: Ctrl+P / Cmd+P → Save as PDF.");
      // optional: open print dialog as best fallback for "download" style
      // window.print(); // this would save as pdf, minimalist serious approach
    });
  }

  // Force no cumulative layout shift for skill bars + prefill if needed
  // ensure project cards have smooth and clean look
  console.log("Minimalist CV ready — Phil Wilson, UniPort");
</script>
