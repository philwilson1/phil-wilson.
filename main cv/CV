<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Phil Wilson · Data & Cyber Security</title>
  <!-- Google Fonts: clean, modern, professional -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background-color: #ffffff;
      color: #1e1f22;
      line-height: 1.5;
      scroll-behavior: smooth;
    }

    /* minimalist container */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2.5rem 1.75rem;
    }

    /* subtle border accents */
    section {
      margin-bottom: 3.25rem;
      border-bottom: 1px solid #e8e8ec;
      padding-bottom: 2.5rem;
    }

    section:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    /* typography — serious & crisp */
    h1 {
      font-size: 3.2rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #0a0b0d;
      margin-bottom: 0.5rem;
      line-height: 1.2;
    }

    .typing-wrapper {
      font-size: 1.4rem;
      font-weight: 500;
      color: #2c3e50;   /* muted slate accent */
      margin-bottom: 0.75rem;
      min-height: 3rem;
    }

    #typed-text {
      border-right: 2px solid #2c3e50;
      padding-right: 5px;
    }

    .tagline {
      font-size: 1rem;
      color: #4a4e5c;
      margin-bottom: 1.25rem;
      border-left: 3px solid #2c3e50;
      padding-left: 1rem;
      font-weight: 400;
    }

    .contact-mini {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      margin: 1.25rem 0 0.5rem;
      font-size: 0.85rem;
      color: #4a4e5c;
      border-top: 1px solid #eceef2;
      padding-top: 1.2rem;
    }

    .contact-mini span {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    /* headings */
    h2 {
      font-size: 1.5rem;
      font-weight: 600;
      letter-spacing: -0.3px;
      color: #0a0b0d;
      margin-bottom: 1.5rem;
      border-left: 4px solid #2c3e50;
      padding-left: 0.9rem;
    }

    h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
      color: #111;
    }

    /* summary */
    .summary-text {
      font-size: 1rem;
      color: #2c2f36;
      max-width: 85%;
      line-height: 1.5;
    }

    /* skills grid + animated bars */
    .skills-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .skill-category {
      flex: 1;
      min-width: 220px;
    }

    .skill-category h3 {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1.2rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #2c3e50;
    }

    .skill-item {
      margin-bottom: 1.2rem;
    }

    .skill-info {
      display: flex;
      justify-content: space-between;
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 0.3rem;
    }

    .skill-bar-bg {
      background-color: #e6e9f0;
      height: 6px;
      border-radius: 4px;
      overflow: hidden;
    }

    .skill-bar-fill {
      width: 0%;
      height: 100%;
      background-color: #2c3e50;
      border-radius: 4px;
      transition: width 0.7s ease-out;
    }

    /* experience & education cards */
    .exp-item, .edu-item, .cert-item {
      margin-bottom: 1.8rem;
    }

    .exp-header {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-bottom: 0.4rem;
    }

    .company {
      font-weight: 600;
      color: #0a0b0d;
    }

    .date {
      font-size: 0.8rem;
      color: #6b7280;
    }

    .exp-list {
      margin-top: 0.6rem;
      padding-left: 1.2rem;
      list-style: none;
    }

    .exp-list li {
      margin-bottom: 0.5rem;
      font-size: 0.92rem;
      color: #2d313a;
      position: relative;
      padding-left: 1rem;
    }

    .exp-list li::before {
      content: "—";
      position: absolute;
      left: 0;
      color: #2c3e50;
      font-weight: 500;
    }

    .edu-detail {
      font-weight: 500;
      margin-bottom: 0.2rem;
    }

    .uni {
      color: #2c3e50;
      font-weight: 500;
    }

    /* certifications chips */
    .certs-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-top: 0.5rem;
    }

    .cert-badge {
      background: #f1f3f7;
      padding: 0.3rem 1rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 500;
      color: #1e293b;
      border: 1px solid #e2e6ec;
    }

    /* interactive project cards */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
      margin-top: 0.5rem;
    }

    .project-card {
      background: #ffffff;
      border: 1px solid #eceef2;
      border-radius: 10px;
      padding: 1.3rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      cursor: default;
    }

    .project-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 18px rgba(0, 0, 0, 0.03), 0 2px 4px rgba(0, 0, 0, 0.02);
      border-color: #d4d8e2;
    }

    .project-card h4 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: #0f172a;
    }

    .project-card p {
      font-size: 0.85rem;
      color: #4a5568;
      margin-bottom: 1rem;
    }

    .tech-tag {
      font-size: 0.7rem;
      background: #f1f5f9;
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 16px;
      color: #2c3e50;
      font-weight: 500;
    }

    /* download btn */
    .btn-download {
      text-align: center;
      margin: 2rem 0 1rem;
    }

    .download-pdf {
      background: none;
      border: 1.5px solid #2c3e50;
      padding: 0.7rem 2rem;
      font-family: inherit;
      font-weight: 600;
      font-size: 0.9rem;
      color: #2c3e50;
      border-radius: 40px;
      cursor: pointer;
      transition: 0.2s;
      background-color: #ffffff;
    }

    .download-pdf:hover {
      background-color: #2c3e50;
      color: white;
    }

    /* footer */
    .footer-note {
      text-align: center;
      font-size: 0.7rem;
      color: #9ca3af;
      margin-top: 2rem;
      padding-top: 1rem;
      border-top: 1px solid #eceef2;
    }

    /* responsive */
    @media (max-width: 720px) {
      .container {
        padding: 1.5rem;
      }
      h1 {
        font-size: 2.4rem;
      }
      .summary-text {
        max-width: 100%;
      }
      .exp-header {
        flex-direction: column;
      }
      .contact-mini {
        gap: 0.8rem;
      }
    }
  </style>
</head>
<body>
